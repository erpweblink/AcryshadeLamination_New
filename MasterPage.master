    <script src="../Content/assets/js/customebynikhil.js"></script>
    <script type="text/javascript">
        function loadNotifications() {
            $.ajax({
                type: "POST",
                url: "/Admin/Dashboard.aspx/GetNotifications",
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                success: function (response) {

                    const data = response.d || [];
                    const list = document.getElementById('notificationList');
                    const count = document.getElementById('notificationCount');

                    const bell = document.getElementById("bellIcon");

                    const currentCount = data.length || 0;
                    count.innerText = currentCount;

                    // 🔴 Continuous alert only based on count
                    if (bell) {
                        if (currentCount > 0) {
                            bell.classList.add("bell-alert");
                        } else {
                            bell.classList.remove("bell-alert");
                        }
                    }

                    // 🔔 Optional: shake ONLY when new notifications arrive
                    if (bell && currentCount > 0) {
                        bell.classList.remove("bell-animate");

                        // restart animation
                        void bell.offsetWidth;

                        bell.classList.add("bell-animate");
                    }


                    let html = '';

                    if (data.length === 0) {
                        html += `
                        <li>
                            <span class="dropdown-item-text text-muted">
                                No notifications
                            </span>
                        </li>`;
                    }
                    else {
                        data.forEach(function (item) {
                            html += `
                        <div class="notification-item order-cardss"
                             data-orderid="${item.Id}">

                            <div class="notification-order">
                                📦 ${item.orderId}
                            </div>

                            <div class="notification-dealer">
                                ${item.dealerName}
                            </div>

                            <div class="notification-meta">
                                Products: ${item.totalProducts}
                                &nbsp;|&nbsp;
                                Qty: ${item.productQty}
                            </div>

                            <div class="notification-time">
                                ${item.orderDate}
                                ${item.holdStatus === "ON HOLD" ? ` &nbsp;|&nbsp; <small style="color:#ff0000;"><b>ON HOLD</b></small>` : ""}           
                            </div>
                        </div>`;
                        });
                    }

                    list.innerHTML = html;
                },
                error: function (xhr, status, error) {
                    console.error("Error loading notifications:", error);
                }
            });
        }

        $(document).on('click', '.order-cardss', function () {
            var orderId = $(this).data('orderid');

            window.location.href =
                'Notifications.aspx?OrderID=' + orderId;
        });

        document.addEventListener('DOMContentLoaded', function () {
            loadNotifications();

            // Refresh every minute
            setInterval(loadNotifications, 60000);
        });
    </script>
